# =============================================================================
# Connessione al database Microsoft SQL Server del gestionale
# Dal gestionale si leggono SOLO: anagrafiche clienti e abbonamenti.
# Il team del gestionale non fornisce utenti SQL: si usa autenticazione Windows.
# =============================================================================

# --- Opzione A: Autenticazione Windows (consigliata) ---
# Accedi con l'account Windows con cui esegui l'app. Crea in autonomia un utente
# (o account di servizio) con permessi di SOLA LETTURA sul database.
# Su Windows: installa il driver opzionale per l'integrated security:
#   pnpm add msnodesqlv8
# Esempio (sostituisci host e nome database):
# SQL_CONNECTION_STRING=Server=nomehost;Database=NomeDatabase;Integrated Security=true;Encrypt=true;TrustServerCertificate=true

# --- Opzione B: Autenticazione SQL (se avete un login SQL con sola lettura) ---
# SQL_CONNECTION_STRING=Server=host;Database=db;User Id=lettura;Password=***;Encrypt=true;TrustServerCertificate=true

# SQL_CONNECTION_STRING=

# Nomi tabelle (default: Utenti, AbbonamentiIscrizione, MovimentiVenduto)
# GESTIONALE_TABLE_CLIENTI=Utenti
# Per avere descrizioni corrette (Abbonamento e Categoria) invece di "Abbonamento"/"Palestra"
# usa la view che espone AbbonamentoDescrizione e CategoriaAbbonamentoDescrizione:
# GESTIONALE_TABLE_ABBONAMENTI=RVW_AbbonamentiUtenti
# GESTIONALE_TABLE_ABBONAMENTI=AbbonamentiIscrizione
# GESTIONALE_TABLE_MOVIMENTI_VENDUTO=MovimentiVenduto

# Colonna venditore in tabella abbonamenti (default IDVenditore; in alcuni DB è Abbonanditore)
# GESTIONALE_ABBONAMENTI_COL_VENDITORE=IDVenditore

# Colonna venditore in MovimentiVenduto: solo quella a cui è attribuita la vendita (non l'operatore).
# GESTIONALE_MOVIMENTI_COL_VENDITORE=IDVenditore
# Se il gestionale filtra per «operatore cassa» e non coincide con IDVenditore, aggiungi colonne (virgola):
# GESTIONALE_MOVIMENTI_COL_VENDITORE_EXTRA=IDOperatore

# --- Venditore da anagrafica clienti (view RVW_AbbonamentiUtentiCapofamiglia) ---
# Il venditore è assegnato in anagrafica; la view espone IDVenditoreAbbonamento e NomeVenditoreAbbonamento.
# Abilita per usare il venditore assegnato al cliente invece delle colonne dirette nelle tabelle.
# GESTIONALE_VIEW_VENDITORE_ABBONAMENTO=RVW_AbbonamentiUtentiCapofamiglia
# GESTIONALE_VIEW_COL_ID_VENDITORE=IDVenditoreAbbonamento
# GESTIONALE_VIEW_COL_NOME_VENDITORE=NomeVenditoreAbbonamento
# GESTIONALE_VIEW_COL_JOIN=IDIscrizione
# Importo riga nella view per somma vendite (default Totale). Se la colonna ha altro nome:
# GESTIONALE_VIEW_COL_TOTALE=Totale

# Date vendite: default UTC (per allineare a SQL). Se i totali restano sbagliati, prova:
# GESTIONALE_DATE_LOCALE=true

# --- Età cliente (grafici attivi adulti/bambini) ---
# Se l'età è nella VIEW abbonamenti (colonna Eta in a.*): non serve nulla, il mapping la legge da solo.
# Se l'età è SOLO sulla tabella Utenti (join u) e la colonna si chiama esattamente Eta:
# GESTIONALE_UTENTI_COL_ETA=Eta
# Altrimenti lascia NON impostato (evita "Invalid column name" se Utenti non ha Eta).
# Soglia anni: sotto = «bambini» nei grafici (default 18)
# ATTIVI_SOGLIA_ETA_ADULTI=18

# ID venditore (IDVenditoreAbbonamento in RVW_AbbonamentiUtenti). Se una consulente vede zero, verifica in SQL gli ID e imposta qui.
# Default: Carmen 278, Serena 348, Ombretta 73 (sostituisci se nel tuo DB sono diversi).
# CONSULENTE_ID_CARMEN=278
# CONSULENTE_ID_SERENA=348
# CONSULENTE_ID_OMBRETTA=73

# Esclusione tesseramenti: usate solo le descrizioni (CategoriaAbbonamentoDescrizione = TESSERAMENTI,
# MacroCategoriaAbbonamentoDescrizione = VARIE o ASI+ISCRIZIONE). Non servono ID.

# Porta API (default 3001)
# PORT=3001

# URL pubblico usato nei link email «firma documento» (consigliato dietro HTTPS)
# Esempio: https://crm.h2sport.it
# SIGN_BASE_URL=https://crm.h2sport.it

# Dietro reverse proxy (Caddy): default trust proxy attivo. Disabilita solo in casi particolari.
# TRUST_PROXY=false

# =============================================================================
# Zapier Webhook (lead)
# Se impostato, il webhook /api/webhook/zapier richiede un token segreto:
# - query string: ?token=...
# - header: X-Zapier-Token: ...
# - oppure Authorization: Bearer ...
# =============================================================================
# ZAPIER_WEBHOOK_TOKEN=

# =============================================================================
# Autenticazione FitCenter
# - Senza AUTH_USERS_JSON: utenti di sviluppo (password in chiaro nel codice sorgente).
# - In produzione: imposta AUTH_USERS_JSON con password in bcrypt (vedi scripts/hash-password.ts).
# Esempio JSON (una riga o file):
# AUTH_USERS_JSON=[{"username":"admin","password":"$2b$12$....","nome":"Admin","role":"admin","email":"tu@dominio.it"}]
#
# Email per secondo passaggio (codice 6 cifre):
# AUTH_LOGIN_EMAIL_OTP=true
# AUTH_USER_EMAILS_JSON={"admin":"admin@h2sport.it"}   (opzionale se già in AUTH_USERS_JSON per utente)
# SMTP:
# AUTH_SMTP_HOST=smtp.example.com
# AUTH_SMTP_PORT=587
# AUTH_SMTP_SECURE=false
# AUTH_SMTP_USER=
# AUTH_SMTP_PASS=
# AUTH_SMTP_FROM="FitCenter <noreply@example.com>"
#
# Policy per nuove password (documentazione / futuro cambio password):
# AUTH_PASSWORD_MIN_LENGTH=12
# =============================================================================
